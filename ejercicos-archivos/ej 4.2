#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define ARCH "c:\\arch.dat"

struct registro
{
    int cliente;
    char nombre[20];
    float saldo;
};

int main()
{
    FILE *arch;
    struct registro reg;
    char seguir;

    if ((arch = fopen(ARCH, "wb")) == NULL)
    {
        printf("No se pudo abrir el archivo\n");
        exit(1);                 
    }

    do
    {
        printf("Ingrese numero de cliente: ");
        scanf("%d", &reg.cliente);

        printf("Ingrese el nombre: ");
        scanf("%s", reg.nombre);  

        printf("Ingrese el saldo: ");
        scanf("%f", &reg.saldo);

        fwrite(&reg, sizeof(reg), 1, arch);

        printf("Desea terminar s/n: ");
        scanf(" %c", &seguir);     

    } while (seguir == 'n');

    fclose(arch);

    printf("Archivo generado correctamente\n");
    return 0;
}
